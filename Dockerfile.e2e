# Standalone image built straight from source, for e2e and local kind runs.
# The release image (Dockerfile) is assembled by goreleaser from a prebuilt
# dist tarball and cannot be produced by a plain `docker build`. This one can.
# The binary lands at /manager to match config/manager (command: [/manager]).
FROM golang:1.26 AS builder
ARG TARGETOS
ARG TARGETARCH

WORKDIR /workspace
COPY go.mod go.mod
COPY go.sum go.sum
RUN go mod download

COPY cmd/ cmd/
COPY api/ api/
COPY internal/ internal/
COPY config/ config/
RUN CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH} go build -a -o manager cmd/main.go

FROM gcr.io/distroless/static:nonroot
WORKDIR /
COPY --from=builder /workspace/manager .
USER 65532:65532
ENTRYPOINT ["/manager"]
